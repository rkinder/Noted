PORT=3001

# PostgreSQL connection (required)
DATABASE_URL=postgres://noted:noted_dev_password@localhost:5432/noted

# IMPORTANT: Change these secrets before deploying
ENCRYPTION_KEY=change-me-to-a-long-random-string
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=7d

# Storage backend for note content: 'local' (default) or 's3'
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data

# S3 settings (required when STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-noted-bucket-name

# For running tests against a separate database
TEST_DATABASE_URL=postgres://noted:noted_dev_password@localhost:5432/noted_test
